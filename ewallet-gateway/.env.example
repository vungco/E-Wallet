# Sao chép thành .env và nạp trước khi chạy: set -a && source .env && set +a && ./gradlew bootRun

SPRING_PROFILES_ACTIVE=dev

# HTTP (FE → gateway). Swagger UI: http://localhost:${SERVER_PORT:-8080}/swagger-ui.html — OpenAPI JSON: /v3/api-docs
SERVER_PORT=8080

# transfer-service gRPC (TransferService) — POST /transfers, poll trạng thái qua gRPC
TRANSFER_GRPC_HOST=localhost
TRANSFER_GRPC_PORT=9093

# wallet-registry gRPC (auth, GET ví) — trùng INTERNAL_API_KEY với wallet-registry khi REQUIRE_INTERNAL_KEY=true
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=9090
WALLET_INTERNAL_API_KEY=

# CORS (FE)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT — trùng JWT_SECRET / JWT_ISSUER với wallet-registry (gateway verify token ở edge)
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32-minimum
JWT_ISSUER=wallet-registry
