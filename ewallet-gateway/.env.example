# Sao chép thành .env và nạp trước khi chạy: set -a && source .env && set +a && ./gradlew bootRun

SPRING_PROFILES_ACTIVE=dev

# HTTP (FE → gateway). Swagger UI: http://localhost:${SERVER_PORT:-8080}/swagger-ui.html — OpenAPI JSON: /v3/api-docs
SERVER_PORT=8080

# transfer-service gRPC (TransferService) — POST /transfers, poll trạng thái qua gRPC
TRANSFER_GRPC_HOST=localhost
TRANSFER_GRPC_PORT=9093
# Optional: key riêng cho transfer; mặc định dùng chuỗi từ WALLET_INTERNAL_API_KEY / INTERNAL_API_KEY (application.yaml)
# TRANSFER_INTERNAL_API_KEY=your-shared-secret

# notification-worker gRPC (NotificationService) — REST thông báo
NOTIFICATION_GRPC_HOST=localhost
NOTIFICATION_GRPC_PORT=9095

# wallet-registry gRPC (auth, GET ví) — trùng giá trị với INTERNAL_API_KEY trên registry khi REQUIRE_INTERNAL_KEY=true
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=9090
# Cùng giá trị với INTERNAL_API_KEY trên wallet-registry khi REQUIRE_INTERNAL_KEY=true.
# Chỉ cần MỘT trong hai: đặt INTERNAL_API_KEY chung HOẶC WALLET_INTERNAL_API_KEY.
# Quan trọng: không để dòng "WALLET_INTERNAL_API_KEY=" (rỗng) — Spring coi là đã set và không dùng default → gateway không gửi header.
# INTERNAL_API_KEY=your-shared-secret
# WALLET_INTERNAL_API_KEY=your-shared-secret

# CORS (FE)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT — trùng JWT_SECRET / JWT_ISSUER với wallet-registry (gateway verify token ở edge)
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32-minimum
JWT_ISSUER=wallet-registry
