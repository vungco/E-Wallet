# Sao chép: cp .env.example .env — Spring không tự đọc .env (export / IDE / Docker env_file)

SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8085

# MySQL — notification_db (Flyway)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=notification_db
DB_USERNAME=root
DB_PASSWORD=example

# Kafka — cùng topic với transfer-service outbox
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=notification-worker
# KAFKA_TOPIC_WALLET_TRANSFER_COMPLETED=wallet.transfer.completed
# KAFKA_TOPIC_WALLET_TRANSFER_FAILED=wallet.transfer.failed

# Redis Pub/Sub — kết quả chuyển tiền → ws-gateway (cùng REDIS_TRANSFER_RESULT_CHANNEL)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TRANSFER_RESULT_CHANNEL=ewallet:transfer:result

# --- Gửi email SMTP (profile smtp) — không set SMTP_HOST → chỉ stub log như cũ ---
# SPRING_PROFILES_ACTIVE=dev,smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.email@gmail.com
# SMTP_PASSWORD=   # App Password 16 ký tự, không commit
# MAIL_FROM=       # Tuỳ chọn; mặc định dùng SMTP_USERNAME
# Địa chỉ nhận lấy từ payload Kafka (fromEmail/toEmail) — không JDBC sang DB khác
