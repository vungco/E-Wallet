# Sao chép thành .env — trùng MySQL root với docker-compose (ví dụ password=example)
SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8084

DB_HOST=localhost
DB_PORT=3306
DB_NAME=audit_db
DB_USERNAME=root
DB_PASSWORD=example

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=audit-worker
KAFKA_TOPIC_WALLET_TRANSFER_COMPLETED=wallet.transfer.completed
