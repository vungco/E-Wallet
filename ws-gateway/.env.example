# Sao chép thành .env — trùng JWT với wallet-registry / transfer-service
SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8083

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=ws-gateway
KAFKA_TOPIC_TRANSFER_RESULT=transfer.result

JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32-minimum
JWT_ISSUER=wallet-registry

# WebSocket CORS (FE), ví dụ: http://localhost:3000,http://127.0.0.1:3000 — để trống = cho phép mọi origin (pattern)
