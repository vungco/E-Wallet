# Sao chép: cp .env.example .env rồi chỉnh giá trị.
# Spring Boot không tự đọc .env — chạy: set -a && source .env && set +a && ./gradlew bootRun
# (hoặc export từng biến / cấu hình Env trong IDE / Docker env_file)

SPRING_PROFILES_ACTIVE=dev

# HTTP
SERVER_PORT=8082

# gRPC API — WALLET_GRPC_HOST / WALLET_GRPC_PORT (wallet-registry WalletRegistryPublic, 9090)
# TRANSFER_GRPC_PORT=9093
# TRANSFER_GRPC_REFLECTION_ENABLED=false

# MySQL — transfer_db (Flyway)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=transfer_db
DB_USERNAME=root
DB_PASSWORD=
# DB_USE_SSL=false
# DB_POOL_MAX=10
# DB_POOL_MIN=2

# JPA
# JPA_SHOW_SQL=false

# Kafka (transfer.command, wallet.transfer.completed — không còn transfer.result, real-time qua Redis)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=transfer-service
# KAFKA_TOPIC_TRANSFER_COMMAND=transfer.command
# KAFKA_TOPIC_WALLET_TRANSFER_COMPLETED=wallet.transfer.completed

# Redis Pub/Sub — kết quả chuyển tiền → ws-gateway (cùng REDIS_TRANSFER_RESULT_CHANNEL)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TRANSFER_RESULT_CHANNEL=ewallet:transfer:result

# JWT — trùng JWT_SECRET / JWT_ISSUER với wallet-registry (verify token)
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32-minimum
JWT_ISSUER=wallet-registry
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=30

# gRPC wallet-registry (DebitWallet/CreditWallet saga + public API) — trùng INTERNAL_API_KEY khi REQUIRE_INTERNAL_KEY=true
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=9090
WALLET_INTERNAL_API_KEY=

# Outbox publisher
# OUTBOX_PUBLISH_INTERVAL_MS=1000
