# Sao chép: cp .env.example .env rồi chỉnh giá trị.
# Spring Boot không tự đọc .env — chạy: set -a && source .env && set +a && ./gradlew bootRun
# (hoặc export từng biến / cấu hình Env trong IDE / Docker env_file)

SPRING_PROFILES_ACTIVE=dev

# HTTP
SERVER_PORT=8082

# gRPC API (ewallet-gateway gọi vào) — tách WALLET_GRPC_PORT (ledger wallet-registry, 9090)
# TRANSFER_GRPC_PORT=9093
# TRANSFER_GRPC_REFLECTION_ENABLED=false

# MySQL — transfer_db (Flyway)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=transfer_db
DB_USERNAME=root
DB_PASSWORD=
# DB_USE_SSL=false
# DB_POOL_MAX=10
# DB_POOL_MIN=2

# JPA
# JPA_SHOW_SQL=false

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=transfer-service
# KAFKA_TOPIC_TRANSFER_COMMAND=transfer.command
# KAFKA_TOPIC_WALLET_TRANSFER_COMPLETED=wallet.transfer.completed
# KAFKA_TOPIC_TRANSFER_RESULT=transfer.result

# JWT — trùng JWT_SECRET / JWT_ISSUER với wallet-registry (verify token)
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32-minimum
JWT_ISSUER=wallet-registry
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=30

# HTTP wallet-registry (kiểm tra ví thuộc user)
WALLET_REGISTRY_BASE_URL=http://localhost:8081

# gRPC ledger — trùng INTERNAL_API_KEY với wallet-registry khi REQUIRE_INTERNAL_KEY=true
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=9090
WALLET_INTERNAL_API_KEY=

# Outbox publisher
# OUTBOX_PUBLISH_INTERVAL_MS=1000
