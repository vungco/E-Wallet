# Sao chép thành .env và nạp trước khi chạy (hoặc export thủ công)

SPRING_PROFILES_ACTIVE=dev

DB_HOST=localhost
DB_PORT=3306
DB_NAME=wallet_db
DB_USERNAME=root
DB_PASSWORD=

SERVER_PORT=8081

# Bật khi cần bảo vệ /internal/** (ví dụ prod)
# REQUIRE_INTERNAL_KEY=true
# INTERNAL_API_KEY=change-me-in-production

# FE Nuxt
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT / refresh (JWT_SECRET >= 32 bytes cho HS256)
# JWT_SECRET=
# JWT_ISSUER=wallet-registry
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=30
