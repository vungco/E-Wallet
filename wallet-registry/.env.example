# Sao chép thành .env và nạp trước khi chạy (hoặc export thủ công)

SPRING_PROFILES_ACTIVE=dev

DB_HOST=localhost
DB_PORT=3306
DB_NAME=wallet_db
DB_USERNAME=root
DB_PASSWORD=example

# HTTP chỉ actuator (health); API công khai là gRPC
SERVER_PORT=8081

# gRPC: một service WalletRegistryPublic (gateway + saga DebitWallet/CreditWallet). Mặc định 9090
# GRPC_PORT=9090
# GRPC_REFLECTION_ENABLED=true
# GRPC_MAX_INBOUND_MESSAGE_SIZE_BYTES=4194304

# Bật khi prod: gateway/transfer-service gửi x-internal-api-key trùng giá trị này
# REQUIRE_INTERNAL_KEY=true
# INTERNAL_API_KEY=change-me-in-production

# JWT / refresh (JWT_SECRET >= 32 bytes cho HS256)
# JWT_SECRET=
# JWT_ISSUER=wallet-registry
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=30
